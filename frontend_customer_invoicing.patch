+import { supabase } from "@/integrations/supabase/client";
+import { fetchFastApi } from "@/lib/ingestion";
+
+export type CustomerContact = {
+  id?: string;
+  contact_name: string;
+  email?: string | null;
+  phone?: string | null;
+  role_title?: string | null;
+  is_primary: boolean;
+};
+
+export type Customer = {
+  id: string;
+  organisation_id: string;
+  customer_code: string | null;
+  legal_name: string;
+  trading_name: string | null;
+  vat_number: string | null;
+  registration_number: string | null;
+  billing_address: string | null;
+  delivery_address: string | null;
+  default_email: string | null;
+  phone: string | null;
+  payment_terms_days: number;
+  currency: string;
+  default_revenue_account_id: string | null;
+  default_vat_treatment: "standard" | "zero_rated" | "exempt";
+  default_tracking: Record<string, string>;
+  active: boolean;
+  contacts?: CustomerContact[];
+};
+
+export type SalesInvoiceLine = {
+  id?: string;
+  description: string;
+  item_code?: string | null;
+  quantity: number;
+  unit_price: number;
+  prices_include_vat: boolean;
+  discount_percent: number;
+  discount_amount: number;
+  vat_treatment: "standard" | "zero_rated" | "exempt";
+  vat_rate: number;
+  revenue_account_id: string;
+  tracking: Record<string, string>;
+  net_amount?: number;
+  tax_amount?: number;
+  gross_amount?: number;
+  source_invoice_extracted_id?: string | null;
+  source_invoice_line_id?: string | null;
+  source_unit_cost?: number | null;
+  markup_percent?: number | null;
+  sort_order: number;
+};
+
+export type SalesInvoice = {
+  id: string;
+  organisation_id: string;
+  customer_id: string;
+  document_type: "invoice" | "credit_note";
+  original_invoice_id: string | null;
+  original_invoice_number?: string | null;
+  credit_reason: string | null;
+  invoice_number: string | null;
+  status: "draft" | "pending_approval" | "approved" | "issued" | "voided";
+  payment_status: "unpaid" | "partial" | "paid" | "overdue";
+  issue_date: string | null;
+  due_date: string | null;
+  currency: string;
+  customer_reference: string | null;
+  purchase_order_number: string | null;
+  notes: string | null;
+  subtotal: number;
+  discount_total: number;
+  tax_total: number;
+  total_amount: number;
+  amount_paid: number;
+  amount_credited: number;
+  amount_outstanding: number;
+  pdf_storage_path: string | null;
+  customer?: Customer;
+  customers?: Pick<Customer, "legal_name" | "trading_name" | "customer_code">;
+  lines?: SalesInvoiceLine[];
+  delivery_events?: Array<Record<string, unknown>>;
+  audit_events?: Array<Record<string, unknown>>;
+  receipt_allocations?: Array<Record<string, unknown>>;
+  credit_notes?: Array<Record<string, unknown>>;
+};
+
+async function arFetch<T>(path: string, init?: RequestInit): Promise<T> {
+  const { data } = await supabase.auth.getSession();
+  const token = data.session?.access_token;
+  if (!token) throw new Error("You must be signed in");
+  const response = await fetchFastApi(path, {
+    ...init,
+    headers: {
+      "Content-Type": "application/json",
+      "ngrok-skip-browser-warning": "true",
+      Authorization: `Bearer ${token}`,
+      ...(init?.headers ?? {}),
+    },
+  });
+  const text = await response.text();
+  const payload = text ? JSON.parse(text) : {};
+  if (!response.ok) {
+    throw new Error(typeof payload?.detail === "string" ? payload.detail : text || `Request failed (${response.status})`);
+  }
+  return payload as T;
+}
+
+export const customerApi = {
+  list: (organisationId: string, includeArchived = false, search = "") =>
+    arFetch<Customer[]>(`/api/customers?${new URLSearchParams({
+      organisation_id: organisationId,
+      include_archived: String(includeArchived),
+      ...(search ? { search } : {}),
+    })}`),
+  get: (organisationId: string, customerId: string) =>
+    arFetch<Customer>(`/api/customers/${customerId}?organisation_id=${organisationId}`),
+  create: (payload: Omit<Customer, "id">) =>
+    arFetch<Customer>("/api/customers", { method: "POST", body: JSON.stringify(payload) }),
+  update: (customerId: string, payload: Omit<Customer, "id">) =>
+    arFetch<Customer>(`/api/customers/${customerId}`, { method: "PUT", body: JSON.stringify(payload) }),
+  archive: (organisationId: string, customerId: string) =>
+    arFetch<Customer>(`/api/customers/${customerId}/archive?organisation_id=${organisationId}`, { method: "POST" }),
+  restore: (organisationId: string, customerId: string) =>
+    arFetch<Customer>(`/api/customers/${customerId}/restore?organisation_id=${organisationId}`, { method: "POST" }),
+};
+
+export const salesInvoiceApi = {
+  list: (organisationId: string, search = "") =>
+    arFetch<SalesInvoice[]>(`/api/sales-invoices?${new URLSearchParams({
+      organisation_id: organisationId,
+      ...(search ? { search } : {}),
+    })}`),
+  get: (organisationId: string, invoiceId: string) =>
+    arFetch<SalesInvoice>(`/api/sales-invoices/${invoiceId}?organisation_id=${organisationId}`),
+  create: (payload: Record<string, unknown>) =>
+    arFetch<SalesInvoice>("/api/sales-invoices", { method: "POST", body: JSON.stringify(payload) }),
+  update: (invoiceId: string, payload: Record<string, unknown>) =>
+    arFetch<SalesInvoice>(`/api/sales-invoices/${invoiceId}`, { method: "PUT", body: JSON.stringify(payload) }),
+  rebill: (invoiceId: string, payload: Record<string, unknown>) =>
+    arFetch(`/api/sales-invoices/${invoiceId}/rebill-lines`, { method: "POST", body: JSON.stringify(payload) }),
+  submit: (invoiceId: string, organisationId: string) =>
+    arFetch(`/api/sales-invoices/${invoiceId}/submit`, { method: "POST", body: JSON.stringify({ organisation_id: organisationId }) }),
+  approve: (invoiceId: string, organisationId: string) =>
+    arFetch(`/api/sales-invoices/${invoiceId}/approve`, { method: "POST", body: JSON.stringify({ organisation_id: organisationId }) }),
+  issue: (invoiceId: string, organisationId: string) =>
+    arFetch(`/api/sales-invoices/${invoiceId}/issue`, { method: "POST", body: JSON.stringify({ organisation_id: organisationId }) }),
+  send: (invoiceId: string, organisationId: string, recipientEmail?: string) =>
+    arFetch(`/api/sales-invoices/${invoiceId}/send`, {
+      method: "POST",
+      body: JSON.stringify({ organisation_id: organisationId, recipient_email: recipientEmail || null }),
+    }),
+  credit: (invoiceId: string, organisationId: string, reason: string) =>
+    arFetch<SalesInvoice>(`/api/sales-invoices/${invoiceId}/credit-notes`, {
+      method: "POST",
+      body: JSON.stringify({ organisation_id: organisationId, reason, lines: [] }),
+    }),
+  pdf: async (invoiceId: string, organisationId: string) => {
+    const { data } = await supabase.auth.getSession();
+    const response = await fetchFastApi(`/api/sales-invoices/${invoiceId}/pdf?organisation_id=${organisationId}`, {
+      headers: { Authorization: `Bearer ${data.session?.access_token ?? ""}`, "ngrok-skip-browser-warning": "true" },
+    });
+    if (!response.ok) throw new Error(await response.text());
+    return response.blob();
+  },
+};
+
+export const customerReceiptApi = {
+  create: (payload: Record<string, unknown>) =>
+    arFetch("/api/customer-receipts", { method: "POST", body: JSON.stringify(payload) }),
+};
