+          <Table>
+            <TableHeader><TableRow><TableHead>Customer</TableHead><TableHead>VAT / Registration</TableHead><TableHead>Contact</TableHead><TableHead>Terms</TableHead><TableHead>Status</TableHead></TableRow></TableHeader>
+            <TableBody>
+              {query.data.map((customer) => (
+                <TableRow key={customer.id} className="cursor-pointer hover:bg-muted/50" onClick={() => void navigate({ to: "/customers/$customerId", params: { customerId: customer.id } })}>
+                  <TableCell><div className="font-medium">{customer.legal_name}</div><div className="text-xs text-muted-foreground">{customer.customer_code || customer.trading_name || "-"}</div></TableCell>
+                  <TableCell><div className="text-xs">VAT: {customer.vat_number || "-"}</div><div className="text-xs text-muted-foreground">Reg: {customer.registration_number || "-"}</div></TableCell>
+                  <TableCell><div className="text-sm">{customer.default_email || "-"}</div><div className="text-xs text-muted-foreground">{customer.phone || ""}</div></TableCell>
+                  <TableCell>{customer.payment_terms_days} days · {customer.currency}</TableCell>
+                  <TableCell><StatusBadge status={customer.active ? "active" : "archived"} /></TableCell>
+                </TableRow>
+              ))}
+            </TableBody>
+          </Table>}
+        </CardContent>
+      </Card>
+    </>
+  );
+}
