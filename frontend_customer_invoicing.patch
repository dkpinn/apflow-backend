+function calculate(line: SalesInvoiceLine) {
+  const extended = Number(line.quantity || 0) * Number(line.unit_price || 0);
+  const discount = line.discount_amount > 0 ? line.discount_amount : extended * Number(line.discount_percent || 0) / 100;
+  const discounted = Math.max(extended - Math.min(discount, extended), 0);
+  const rate = line.vat_treatment === "standard" ? Number(line.vat_rate || 0) : 0;
+  const gross = line.prices_include_vat && rate ? discounted : discounted * (1 + rate / 100);
+  const net = line.prices_include_vat && rate ? gross / (1 + rate / 100) : discounted;
+  return { net: Math.round(net * 100) / 100, tax: Math.round((gross - net) * 100) / 100, gross: Math.round(gross * 100) / 100 };
