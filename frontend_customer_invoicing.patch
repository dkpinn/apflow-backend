+import { createFileRoute, useNavigate } from "@tanstack/react-router";
+import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
+import { useEffect, useState, type ReactNode } from "react";
+import { ArrowLeft, Archive, Loader2, Save } from "lucide-react";
+import { toast } from "sonner";
+import { Button } from "@/components/ui/button";
+import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
+import { Input } from "@/components/ui/input";
+import { Label } from "@/components/ui/label";
+import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
+import { Textarea } from "@/components/ui/textarea";
+import { PageHeader } from "@/components/app/PageHeader";
+import { useOrg } from "@/lib/org";
+import { usePermissions } from "@/lib/permissions";
+import { customerApi, type Customer } from "@/lib/customerInvoicing";
+
+export const Route = createFileRoute("/_app/customers/$customerId")({ component: CustomerEditor });
+
+const empty = (organisationId = ""): Omit<Customer, "id"> => ({
+  organisation_id: organisationId, customer_code: "", legal_name: "", trading_name: "", vat_number: "",
+  registration_number: "", billing_address: "", delivery_address: "", default_email: "", phone: "",
+  payment_terms_days: 30, currency: "ZAR", default_revenue_account_id: null,
+  default_vat_treatment: "standard", default_tracking: {}, active: true, contacts: [],
+});
+
+function CustomerEditor() {
+  const { customerId } = Route.useParams();
+  const isNew = customerId === "new";
+  const { currentOrgId } = useOrg();
+  const { canEditData } = usePermissions();
+  const navigate = useNavigate();
+  const qc = useQueryClient();
+  const [form, setForm] = useState<Omit<Customer, "id">>(empty(currentOrgId ?? ""));
+  const query = useQuery({
+    queryKey: ["customer", currentOrgId, customerId],
+    enabled: Boolean(currentOrgId && !isNew),
+    queryFn: () => customerApi.get(currentOrgId!, customerId),
+  });
+  useEffect(() => {
+    if (query.data) {
+      const { id: _id, ...rest } = query.data;
+      setForm(rest);
+    } else if (isNew && currentOrgId) setForm(empty(currentOrgId));
+  }, [query.data, isNew, currentOrgId]);
+
+  const save = useMutation({
+    mutationFn: () => isNew ? customerApi.create(form) : customerApi.update(customerId, form),
+    onSuccess: async (customer) => {
+      toast.success(isNew ? "Customer created" : "Customer saved");
+      await qc.invalidateQueries({ queryKey: ["customers", currentOrgId] });
+      if (isNew) void navigate({ to: "/customers/$customerId", params: { customerId: customer.id }, replace: true });
+    },
+    onError: (error) => toast.error((error as Error).message),
+  });
+  const archive = useMutation({
+    mutationFn: () => form.active ? customerApi.archive(currentOrgId!, customerId) : customerApi.restore(currentOrgId!, customerId),
+    onSuccess: (customer) => { setForm((old) => ({ ...old, active: customer.active })); toast.success(customer.active ? "Customer restored" : "Customer archived"); },
+    onError: (error) => toast.error((error as Error).message),
+  });
+  const set = <K extends keyof typeof form>(key: K, value: (typeof form)[K]) => setForm((old) => ({ ...old, [key]: value }));
+
+  return (
+    <>
+      <PageHeader
+        title={isNew ? "New Customer" : form.legal_name || "Customer"}
+        actions={<>
+          <Button variant="outline" onClick={() => void navigate({ to: "/customers" })}><ArrowLeft className="mr-2 h-4 w-4" /> Back</Button>
+          {!isNew && <Button variant="outline" disabled={!canEditData || archive.isPending} onClick={() => archive.mutate()}><Archive className="mr-2 h-4 w-4" />{form.active ? "Archive" : "Restore"}</Button>}
+          <Button disabled={!canEditData || save.isPending || !form.legal_name.trim()} onClick={() => save.mutate()}>{save.isPending ? <Loader2 className="mr-2 h-4 w-4 animate-spin" /> : <Save className="mr-2 h-4 w-4" />} Save</Button>
+        </>}
+      />
+      <div className="grid gap-4 lg:grid-cols-2">
+        <Card><CardHeader><CardTitle className="text-base">Identity</CardTitle></CardHeader><CardContent className="grid gap-4 sm:grid-cols-2">
+          <Field label="Legal name"><Input value={form.legal_name} onChange={(e) => set("legal_name", e.target.value)} /></Field>
+          <Field label="Trading name"><Input value={form.trading_name ?? ""} onChange={(e) => set("trading_name", e.target.value)} /></Field>
+          <Field label="Customer code"><Input value={form.customer_code ?? ""} onChange={(e) => set("customer_code", e.target.value)} /></Field>
+          <Field label="VAT number"><Input value={form.vat_number ?? ""} onChange={(e) => set("vat_number", e.target.value)} /></Field>
+          <Field label="Registration number"><Input value={form.registration_number ?? ""} onChange={(e) => set("registration_number", e.target.value)} /></Field>
+          <Field label="Currency"><Input maxLength={3} value={form.currency} onChange={(e) => set("currency", e.target.value.toUpperCase())} /></Field>
+        </CardContent></Card>
+        <Card><CardHeader><CardTitle className="text-base">Billing defaults</CardTitle></CardHeader><CardContent className="grid gap-4 sm:grid-cols-2">
+          <Field label="Invoice email"><Input type="email" value={form.default_email ?? ""} onChange={(e) => set("default_email", e.target.value)} /></Field>
+          <Field label="Phone"><Input value={form.phone ?? ""} onChange={(e) => set("phone", e.target.value)} /></Field>
+          <Field label="Payment terms days"><Input type="number" min={0} value={form.payment_terms_days} onChange={(e) => set("payment_terms_days", Number(e.target.value || 0))} /></Field>
+          <Field label="Default VAT treatment"><Select value={form.default_vat_treatment} onValueChange={(v) => set("default_vat_treatment", v as typeof form.default_vat_treatment)}><SelectTrigger><SelectValue /></SelectTrigger><SelectContent><SelectItem value="standard">Standard 15%</SelectItem><SelectItem value="zero_rated">Zero rated</SelectItem><SelectItem value="exempt">Exempt</SelectItem></SelectContent></Select></Field>
+        </CardContent></Card>
+        <Card><CardHeader><CardTitle className="text-base">Billing address</CardTitle></CardHeader><CardContent><Textarea rows={7} value={form.billing_address ?? ""} onChange={(e) => set("billing_address", e.target.value)} /></CardContent></Card>
+        <Card><CardHeader><CardTitle className="text-base">Delivery address</CardTitle></CardHeader><CardContent><Textarea rows={7} value={form.delivery_address ?? ""} onChange={(e) => set("delivery_address", e.target.value)} /></CardContent></Card>
+      </div>
+    </>
+  );
+}
+
+function Field({ label, children }: { label: string; children: ReactNode }) {
+  return <div className="space-y-1.5"><Label>{label}</Label>{children}</div>;
+}
